{
  "name": "hana-connect-front",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "commit": "cz",
    "dev": "next dev",
    "format": "biome format --write",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true",
    "prepare": "simple-git-hooks",
    "start": "next start"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm build"
  },
  "lint-staged": {
    "*.{css,js,json,jsx,ts,tsx}": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true",
    "package.json": "sort-package-json"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/prompt": "^20.1.0",
    "@commitlint/types": "^20.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "Button": "^0.0.1",
    "clsx": "^2.1.1",
    "commitlint": "^20.1.0",
    "framer-motion": "^12.38.0",
    "git-cz": "^4.9.0",
    "lint-staged": "^16.2.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "sort-package-json": "^3.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cz-commitlint": "^20.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
